# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=agentic_funding

# Agent API Keys
UNBROWSE_API_KEY=
ARKHAI_API_KEY=

# Solana Diligence Enrichment
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_COMMITMENT=finalized
SOLANA_RECENT_SIGNATURE_LIMIT=25
SOLANA_ANALYTICS_PROVIDER=rpc_history
SOLANA_ANALYTICS_SIGNATURE_LIMIT=100
SOLANA_TIMEOUT_SECONDS=20
SOLANA_MAX_RETRIES=2

# GitHub API Enrichment
GITHUB_API_URL=https://api.github.com
GITHUB_API_TOKEN=
GITHUB_TIMEOUT_SECONDS=20
GITHUB_MAX_RETRIES=2
GITHUB_COMMITS_LOOKBACK_DAYS=90
GITHUB_MAX_PAGES=5
SCORING_NODE_EXECUTABLE=node

# Gemini / Gemma Market Intelligence
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MARKET_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=0
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=5.0
MARKET_SEARCH_TIMEOUT_SECONDS=12
MARKET_SEARCH_RESULTS_PER_QUERY=2
MARKET_MAX_SOURCE_DOCUMENTS=4

# Alkahest / On-Chain Payment Config (Base Sepolia)
ORACLE_PRIVATE_KEY=       # EVM wallet private key (0x...) - generate via MetaMask or script
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org   # Override with Alchemy URL for reliability
ORACLE_WALLET_ADDRESS=    # Public address of the oracle wallet
ESCROW_GROWTH_TARGET=30.0  # % user growth required to release escrow
ESCROW_CHECK_INTERVAL_MINUTES=60
