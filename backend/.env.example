# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=agentic_funding

# Agent API Keys
UNBROWSE_API_KEY=
ARKHAI_API_KEY=

# Solana Diligence Enrichment
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_COMMITMENT=finalized
SOLANA_RECENT_SIGNATURE_LIMIT=25
SOLANA_ANALYTICS_PROVIDER=rpc_history
SOLANA_ANALYTICS_SIGNATURE_LIMIT=100
SOLANA_TIMEOUT_SECONDS=20
SOLANA_MAX_RETRIES=2

# GitHub API Enrichment
GITHUB_API_URL=https://api.github.com
GITHUB_API_TOKEN=
GITHUB_TIMEOUT_SECONDS=20
GITHUB_MAX_RETRIES=2
GITHUB_COMMITS_LOOKBACK_DAYS=90
GITHUB_MAX_PAGES=5
SCORING_NODE_EXECUTABLE=node
DECISION_NODE_EXECUTABLE=node
TREASURY_NODE_EXECUTABLE=node

# Gemini / Gemma Market Intelligence
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MARKET_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=0
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=5.0
MARKET_SEARCH_TIMEOUT_SECONDS=12
MARKET_SEARCH_RESULTS_PER_QUERY=2
MARKET_MAX_SOURCE_DOCUMENTS=4

# Treasury Management
TREASURY_TOTAL_CAPITAL=1000000
TREASURY_HOT_RESERVE_RATIO=0.15
TREASURY_STRATEGIC_BUFFER_RATIO=0.10
TREASURY_HOT_WINDOW_DAYS=30
TREASURY_MAX_IDLE_DEPLOYMENT_RATIO=0.85
TREASURY_MAX_SINGLE_VAULT_ALLOCATION_RATIO=0.60
TREASURY_MARKET_RISK_OFF=false
TREASURY_MARKET_VOLATILITY_SCORE=30
TREASURY_MARKET_LIQUIDITY_STRESS_SCORE=20
TREASURY_MARKET_WITHDRAWAL_DEMAND_SCORE=20
TREASURY_MARKET_MIN_AVERAGE_APY_PCT=2.0
TREASURY_MARKET_MIN_WITHDRAWABLE_COVERAGE_RATIO=0.40
TREASURY_MARKET_MIN_STRATEGY_COUNT=1
TREASURY_METEORA_ENABLED=false
TREASURY_METEORA_TOKEN_SYMBOLS=USDC,SOL
TREASURY_METEORA_CLUSTER=devnet
TREASURY_METEORA_RPC_URL=
TREASURY_METEORA_DYNAMIC_VAULT_API_URL=https://merv2-api.meteora.ag
TREASURY_METEORA_TIMEOUT_SECONDS=15
TREASURY_METEORA_TOKEN_MINT_OVERRIDES=
DECISION_AGENT_MODE=gemini
DECISION_AGENT_MODEL=gemini-3.1-flash-lite-preview
DECISION_TIMEOUT_SECONDS=45
DECISION_MAX_RETRIES=0
DECISION_MIN_REQUEST_INTERVAL_SECONDS=5
DECISION_ALLOW_HEURISTIC_FALLBACK=true
DECISION_PER_PROPOSAL_CAP_RATIO=0.20
DECISION_SECTOR_EXPOSURE_CAP_RATIO=0.35
DECISION_MINIMUM_FUNDABLE_SCORE=60
DECISION_MINIMUM_ACCEPT_SCORE=78
DECISION_MINIMUM_CONFIDENCE=0.45
DECISION_HIGH_RISK_REJECT_BELOW_SCORE=72
DECISION_HIGH_RISK_MIN_CONFIDENCE=0.55
DECISION_MAX_REVISION_ATTEMPTS=3
DECISION_MAX_MILESTONE_COUNT=5

# Alkahest / On-Chain Payment Config (Base Sepolia)
ORACLE_PRIVATE_KEY=       # EVM wallet private key (0x...) - generate via MetaMask or script
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org   # Override with Alchemy URL for reliability
ORACLE_WALLET_ADDRESS=    # Public address of the oracle wallet
ESCROW_GROWTH_TARGET=30.0  # % user growth required to release escrow
ESCROW_CHECK_INTERVAL_MINUTES=60
